# Grocer-E Docker environment configuration
# Used for docker-compose.yml deployment

NODE_ENV=development
PORT=5000

# Database configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=grocere_db
DB_USER=grocere_user
DB_PASSWORD=grocere_password

# JWT Configuration
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRE=30d

# Password validation
MIN_PASSWORD_LENGTH=8

# Gemini API Configuration (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
